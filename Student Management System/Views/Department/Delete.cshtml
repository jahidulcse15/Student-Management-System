@model Student_Management_System.Models.Department

@{
    ViewData["Title"] = "Delete Department";
}

<div class="container mt-5">

    <div class="card shadow border-0">

        <div class="card-header bg-danger text-white">
            <h3 class="mb-0">Delete Department</h3>
        </div>

        <div class="card-body">

            <div class="alert alert-warning">
                <strong>Warning!</strong> Are you sure you want to delete this department?
            </div>

            <div class="table-responsive">

                <table class="table table-bordered table-hover text-center align-middle">

                    <thead class="table-dark">
                        <tr>
                            <th>Id</th>
                            <th>Department Name</th>
                            <th>Total Enrolled Students</th>
                        </tr>
                    </thead>

                    <tbody>
                        <tr>
                            <td>@Model.Id</td>
                            <td>@Model.Name</td>
                            <td>
                                <span class="badge bg-primary fs-6">
                                    @Model.Student.Count()
                                </span>
                            </td>
                        </tr>
                    </tbody>

                </table>

            </div>

            <form asp-action="ConfirmDelete"
                  asp-controller="Department"
                  method="post">

                <input type="hidden" name="id" value="@Model.Id" />

                <div class="mt-4 text-center">

                    <button type="submit" class="btn btn-danger me-2">
                        Confirm Delete
                    </button>

                    <a asp-action="Index"
                       asp-controller="Department"
                       class="btn btn-success">
                        Back To List
                    </a>

                </div>

            </form>

        </div>

    </div>

</div>