@model Student_Management_System.Models.Student

@{
    ViewData["Title"] = "Create Student";
}

<div class="container mt-4">

    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h3 class="mb-0">Create New Student</h3>
        </div>

        <div class="card-body">

            <form asp-action="Create" method="post">

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Student Name</label>
                        <input asp-for="Name" class="form-control" />
                    </div>

                    

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Registration Number</label>
                        <input asp-for="RegistrationNumber" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Email</label>
                        <input asp-for="Email" type="email" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Phone</label>
                        <input asp-for="PhoneNumber" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Gender</label>
                        <select asp-for="Gender" class="form-select">
                            <option value="">Select Gender</option>
                            <option>Male</option>
                            <option>Female</option>
                            <option>Other</option>
                        </select>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Date of Birth</label>
                        <input asp-for="DateOfBirth" type="date" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">GPA</label>
                        <input asp-for="GPA" class="form-control" />
                    </div>

                    <div class="col-md-12 mb-3">
                        <label class="form-label">Address</label>
                        <textarea asp-for="Address" rows="3" class="form-control"></textarea>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Department</label>
                        <select asp-for="DepartmentId" class="form-select">
                            <option value="">Select Department</option>
                            <option value="1">CSE</option>
                            <option value="2">EEE</option>
                            <option value="3">BBA</option>
                        </select>
                    </div>

                </div>

                <div class="mt-3">
                    <button type="submit" class="btn btn-success">
                        Save Student
                    </button>

                    <a asp-action="Index" class="btn btn-secondary">
                        Back to List
                    </a>
                </div>

            </form>

        </div>
    </div>

</div>