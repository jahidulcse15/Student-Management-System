<!DOCTYPE html>
<html>
<head>
    <title>Student Management Dashboard</title>

    <!-- Bootstrap CDN -->
    
</head>

<body class="bg-light">

    <!-- Title -->
    <div class="container mt-4">
        <h2 class="text-center fw-bold text-primary">
            Student Management System Dashboard
        </h2>
    </div>

    <div class="container mt-4">

        <!-- Cards Row -->
        <div class="row g-3">

            <div class="col-md-3">
                <div class="card shadow-sm border-0 text-center bg-primary text-white">
                    <div class="card-body">
                        <h2 class="fw-bold">120</h2>
                        <p>Total Students</p>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card shadow-sm border-0 text-center bg-success text-white">
                    <div class="card-body">
                        <h2 class="fw-bold">5</h2>
                        <p>Total Departments</p>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card shadow-sm border-0 text-center bg-warning text-dark">
                    <div class="card-body">
                        <h2 class="fw-bold">3.45</h2>
                        <p>Average CGPA</p>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card shadow-sm border-0 text-center bg-danger text-white">
                    <div class="card-body">
                        <h2 class="fw-bold">4.00</h2>
                        <p>Highest CGPA</p>
                    </div>
                </div>
            </div>

        </div>

        <!-- Table Section -->
        <div class="card shadow-sm border-0 mt-4">
            <div class="card-body">

                <h5 class="mb-3 fw-bold">Recently Added Students</h5>

                <table class="table table-hover table-striped">
                    <thead class="table-dark">
                        <tr>
                            <th>Name</th>
                            <th>Department</th>
                            <th>CGPA</th>
                        </tr>
                    </thead>

                    <tbody>
                        <tr>
                            <td>Jahid</td>
                            <td>CSE</td>
                            <td>3.80</td>
                        </tr>
                        <tr>
                            <td>Karim</td>
                            <td>EEE</td>
                            <td>3.60</td>
                        </tr>
                        <tr>
                            <td>Rahim</td>
                            <td>BBA</td>
                            <td>3.70</td>
                        </tr>
                    </tbody>
                </table>

            </div>
        </div>

    </div>

</body>
</html>