@model List<Student_Management_System.Models.Department>

@{
    ViewData["Title"] = "Dashboard";

    double TotalStudent = 0;
    double TotalDepartment = 0;
    double HighestCgpa = 0;
    double LowestCgpa = Double.MaxValue;
    double SumCgpa = 0;

    int male = 0;
    int female = 0;
}

@{
    foreach (var item in ViewBag.AllStudentList)
    {
        SumCgpa += item.GPA;

        HighestCgpa = Math.Max(HighestCgpa, item.GPA);
        LowestCgpa = Math.Min(LowestCgpa, item.GPA);

        if (item.Gender == "Male")
        {
            male++;
        }
        else if (item.Gender == "Female")
        {
            female++;
        }
    }
}

@{
    foreach (var item in Model)
    {
        TotalDepartment++;

        if (item.Student != null)
        {
            TotalStudent += item.Student.Count();
        }
    }
}

<div class="container-fluid py-4">

    <div class="text-center mb-4">
        <h1 class="fw-bold text-primary">
            Student Management Dashboard
        </h1>
        <h3 class="text-muted">
            Overview of Students and Departments
        </h3>
    </div>

    <!-- Statistics Cards -->
    <div class="row g-4">

        <div class="col-12 col-sm-6 col-md-4 col-xl">
            <div class="card border-0 shadow h-100 bg-primary text-white">
                <div class="card-body text-center">
                    <h5>Total Students</h5>
                    <h2 class="fw-bold">@TotalStudent</h2>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-md-4 col-xl">
            <div class="card border-0 shadow h-100 bg-success text-white">
                <div class="card-body text-center">
                    <h5>Total Departments</h5>
                    <h2 class="fw-bold">@TotalDepartment</h2>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-md-4 col-xl">
            <div class="card border-0 shadow h-100 bg-warning text-dark">
                <div class="card-body text-center">
                    <h5>Average CGPA</h5>
                    <h2 class="fw-bold">
                        @(TotalStudent > 0
                                                ? (SumCgpa / TotalStudent).ToString("F2")
                                                : "0.00")
                    </h2>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-md-4 col-xl">
            <div class="card border-0 shadow h-100 bg-danger text-white">
                <div class="card-body text-center">
                    <h5>Highest CGPA</h5>
                    <h2 class="fw-bold">@HighestCgpa</h2>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-md-4 col-xl">
            <div class="card border-0 shadow h-100 bg-dark text-white">
                <div class="card-body text-center">
                    <h5>Lowest CGPA</h5>
                    <h2 class="fw-bold">
                        @(LowestCgpa == Double.MaxValue ? 0 : LowestCgpa)
                    </h2>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-md-4 col-xl">
            <div class="card border-0 shadow h-100 bg-info text-white">
                <div class="card-body text-center">
                    <h5>Male Students</h5>
                    <h2 class="fw-bold">@male</h2>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-md-4 col-xl">
            <div class="card border-0 shadow h-100 bg-secondary text-white">
                <div class="card-body text-center">
                    <h5>Female Students</h5>
                    <h2 class="fw-bold">@female</h2>
                </div>
            </div>
        </div>

    </div>

    <!-- Recently Added Students -->
    <div class="card border-0 shadow mt-5">

        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">
                Recently Added Students
            </h4>
        </div>

        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-hover table-striped align-middle">

                    <thead class="table-dark">
                        <tr>
                            <th>Name</th>
                            <th>Department</th>
                            <th>CGPA</th>
                        </tr>
                    </thead>

                    <tbody>

                        @if (ViewBag.StudentList != null)
                        {
                            @foreach (var item in ViewBag.StudentList)
                            {
                                <tr>
                                    <td>@item.Name</td>

                                    <td>
                                        @item.Department?.Name
                                    </td>

                                    <td>
                                        <span class="badge bg-success fs-6">
                                            @item.GPA
                                        </span>
                                    </td>
                                </tr>
                            }
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>